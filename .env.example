# Environment variables for local development
# For production, use Docker Secrets (see docker-compose.yml)

# PostgreSQL connection string
DATABASE_URL="postgresql://admin:password@localhost:5432/plpp_cloud"

# AES-256-GCM encryption key (32 bytes = 64 hex characters)
# Generate a new key with: openssl rand -hex 32
ENCRYPTION_KEY="<64-char-hex-key>"

# Node environment (set to "production" in production for secure cookies)
NODE_ENV="development"

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS="http://localhost:5173"
