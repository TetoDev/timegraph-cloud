// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}


model User {
  id       String    @id @default(uuid())
  username String    @unique
  email    String    @unique
  password String    

  emailVerified         Boolean   @default(false)
  verificationCode      String?
  verificationExpiresAt DateTime?

  totpSecret   String?
  totpEnabled  Boolean @default(false)

  sessions Session[]
  
  ownedProjects    Project[]             @relation("ProjectOwner")
  collaborations   ProjectCollaborator[]
  ownedGroups      ShareGroup[]          @relation("GroupOwner")
  groupMemberships ShareGroupMember[]

  createdPartRefs  PartReference[]       @relation("PartRefCreatedBy")
  updatedPartRefs  PartReference[]       @relation("PartRefUpdatedBy")
  createdBomLists  SharedBomList[]        @relation("BomListCreatedBy")
  updatedBomLists  SharedBomList[]        @relation("BomListUpdatedBy")

  recoveryCodes RecoveryCode[]
  resetTokens   PasswordResetToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id        String   @id @default(uuid())
  name      String
  data      Json?
  yjsState  Bytes?

  dataKey   String?
  dataIV    String?
  deKIV     String?
  encrypted Boolean  @default(false)
  
  ownerId   String
  owner     User     @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  
  collaborators ProjectCollaborator[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  READ
  WRITE
}

model ProjectCollaborator {
  projectId String
  userId    String
  role      Role     @default(READ)
  
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@id([projectId, userId]) 
}

model ShareGroup {
  id        String   @id @default(uuid())
  name      String
  
  ownerId   String
  owner     User     @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  
  members   ShareGroupMember[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShareGroupMember {
  groupId   String
  userId    String

  group     ShareGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
}

model RecoveryCode {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hash      String
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model PartReference {
  id              String   @id @default(uuid())
  componentNumber String   @unique
  description     String   @default("")
  weight          Float    @default(0)

  createdById     String?
  createdBy       User?    @relation("PartRefCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById     String?
  updatedBy       User?    @relation("PartRefUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([componentNumber])
}

model SharedBomList {
  id         String   @id @default(uuid())
  name       String
  partNumber String   @default("")
  drawing    String   @default("")
  items      String                     // JSON-encrypted BomItem[]

  createdById String?
  createdBy   User?    @relation("BomListCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   User?    @relation("BomListUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}